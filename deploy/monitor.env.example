# Install as /etc/paper-mes/monitor.env with mode 0640 and group paper-mes.
HEALTH_URL=http://127.0.0.1:8081/actuator/health
PUBLIC_URL=
BACKUP_ROOT=/opt/backups/paper-mes
MAX_BACKUP_AGE_HOURS=48
MIN_BACKUP_FREE_MB=1024
HTTP_TIMEOUT_SECONDS=10

# Optional. Keep credentials only in /etc/paper-mes/monitor.env.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_BEARER_TOKEN=
