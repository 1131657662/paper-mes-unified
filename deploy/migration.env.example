# Copy to /etc/paper-mes/migration.env and run:
#   sudo chmod 600 /etc/paper-mes/migration.env
#
# This account needs DDL permissions during deployment.
# Do not commit the real file with production passwords.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=paper_processing
DB_USER=paper_mes_app
DB_PASSWORD=CHANGE_ME_DDL_PASSWORD
MIGRATION_DIR=/opt/paper-mes/source/sql
