# Copy to /etc/paper-mes/paper-mes.env and chmod 600.
# Keep real credentials outside the repository.
PAPER_MES_DB_USER=paper_mes_app
PAPER_MES_DB_PASSWORD=CHANGE_ME_APP_PASSWORD
PAPER_MES_SCHEMA_BOOTSTRAP_ENABLED=false
APP_INITIAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
APP_INITIAL_OPERATOR_PASSWORD=CHANGE_ME_STRONG_OPERATOR_PASSWORD
