# Copy to /etc/paper-mes/backup.env and run:
#   sudo chmod 600 /etc/paper-mes/backup.env
#
# Do not commit the real file with production passwords.

BACKUP_ROOT=/opt/backups/paper-mes
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=paper_processing
DB_USER=paper_mes_backup
DB_PASSWORD=CHANGE_ME_BACKUP_PASSWORD
UPLOAD_DIR=/opt/paper-mes/upload
RETENTION_DAYS=14
