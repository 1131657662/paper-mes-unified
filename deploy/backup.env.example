# Copy to /etc/paper-mes/backup.env and run:
#   sudo chmod 600 /etc/paper-mes/backup.env
#
# Do not commit the real file with production passwords.

BACKUP_ROOT=/opt/backups/paper-mes
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=paper_processing
DB_USER=paper_mes_backup
DB_PASSWORD=CHANGE_ME_BACKUP_PASSWORD
UPLOAD_DIR=/opt/paper-mes/upload

# Restore verification and controlled restore use a privileged account.
# Prefer a dedicated account with only the required database privileges.
DB_ADMIN_HOST=127.0.0.1
DB_ADMIN_PORT=3306
DB_ADMIN_USER=paper_mes_restore
DB_ADMIN_PASSWORD=CHANGE_ME_RESTORE_PASSWORD
RESTORE_DB_NAME=paper_mes_restore_check
DROP_AFTER_VERIFY=true

# Production restore stays disabled unless explicitly enabled for one command.
PRODUCTION_DB_NAME=paper_processing
ALLOW_PRODUCTION_RESTORE=false

# Optional off-site copy. Credentials belong in the root-only rclone config.
RCLONE_REMOTE=paper_mes_archive
RCLONE_PATH=paper-mes-backups
