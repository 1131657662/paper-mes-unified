        { "theme": { "mode": "light" }, "value": "#F7FAFF" },
        { "theme": { "mode": "dark" }, "value": "#0F172A" }
      ]
    },
    "color.text": {
      "type": "color",
      "value": [
        { "theme": { "mode": "light" }, "value": "#111827" },
        { "theme": { "mode": "dark" }, "value": "#F8FAFC" }
      ]
    }
  },
