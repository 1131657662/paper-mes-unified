{
  "version": "2.8",
  "themes": {
    "mode": ["light", "dark"]
  },
  "variables": {
    "color.primary": {
      "type": "color",
      "value": [
        { "theme": { "mode": "light" }, "value": "#2563EB" },
        { "theme": { "mode": "dark" }, "value": "#4F8EFF" }
      ]
    },
    "color.secondary": {
      "type": "color",
      "value": [
        { "theme": { "mode": "light" }, "value": "#5B8CFF" },
        { "theme": { "mode": "dark" }, "value": "#8AB4FF" }
      ]
    },
    "color.surface": {
      "type": "color",
