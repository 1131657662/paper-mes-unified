  "children": [
    {
      "type": "frame",
      "id": "screen-config",
      "name": "01 成品配置工作台",
      "theme": {
        "mode": "light"
      },
      "x": 0,
      "y": 0,
      "width": 1440,
      "height": "fit_content",
      "fill": "$color.bg",
      "layout": "vertical",
      "gap": 0,
      "children": [
        {
          "type": "frame",
          "id": "cfg-topbar",
          "width": "fill_container",
          "height": 56,
          "layout": "horizontal",
          "alignItems": "center",
          "justifyContent": "space_between",
          "padding": [
            "$space.lg",
            "$space.xl",
            "$space.lg",
            "$space.xl"
          ],
          "fill": "$color.surface",
          "stroke": {
            "align": "inside",
            "thickness": "$stroke.thickness.default",
            "fill": "$color.border"
          },
          "children": [
            {
              "type": "frame",
              "layout": "vertical",
              "gap": 2,
              "children": [
                {
                  "type": "text",
                  "content": "成品规格配置",
                  "textGrowth": "auto",
                  "fontSize": "$font.size.lg",
                  "fontFamily": "$font.family.display",
                  "fontWeight": "$font.weight.bold",
                  "fill": "$color.foreground"
                },
                {
                  "type": "text",
                  "content": "JG20250625001 · 华东纸业",
                  "textGrowth": "auto",
                  "fontSize": "$font.size.sm",
                  "fontFamily": "$font.family.body",
                  "fontWeight": "$font.weight.regular",
                  "fill": "$color.muted"
                }
              ]
            },
            {
              "type": "frame",
              "layout": "horizontal",
              "gap": "$space.sm",
              "children": [
                {
                  "type": "frame",
                  "layout": "horizontal",
                  "alignItems": "center",
                  "justifyContent": "center",
