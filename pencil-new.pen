                    "align": "inside",
                    "thickness": 1,
                    "fill": "$color.border"
                  },
                  "fill": "$color.surface",
                  "children": [
                    {
                      "type": "text",
                      "content": "取消",
                      "textGrowth": "auto",
                      "fontSize": "$font.size.sm",
                      "fontFamily": "$font.family.body",
                      "fontWeight": "$font.weight.regular",
                      "fill": "$color.foreground"
